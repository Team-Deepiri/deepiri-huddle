# REQUIRED: pick at least one live LLM path
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b

# OPTIONAL cloud providers
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LLM_PROVIDER_ORDER=ollama,deepseek,gemini,openrouter,openai
LLM_TIMEOUT_SECONDS=120

# Logging: DEBUG, INFO, WARNING, ... (applies to the ``huddle`` package logger on stderr)
HUDDLE_LOG_LEVEL=INFO

# Optional Discord context
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ANNOUNCEMENTS_CHANNEL=announcements
DISCORD_FETCH_LIMIT=20

# Local memory
MEMORY_FILE=.huddle/memory.jsonl
